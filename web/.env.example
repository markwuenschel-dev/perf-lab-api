# Web frontend (Vite) environment — copy to .env.local for local dev.
# Vite only exposes vars prefixed with VITE_ to the browser bundle, and they are
# inlined at BUILD time — pass this as a Docker `--build-arg` so it gets baked
# into the image at build time (see Dockerfile / web/Dockerfile).

# Base URL of the perf-lab-api backend (no trailing slash). The client appends
# /v1 and /auth itself (see src/api/perfLabClient.ts). If unset, the app runs
# fully local (guest/demo) and every backend call is skipped.
#
# Local dev (api on :8000):   http://localhost:8000
# Production:                  same-origin monolith build — see docs/DEPLOY.md
VITE_API_BASE_URL=http://localhost:8000
