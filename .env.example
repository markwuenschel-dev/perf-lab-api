# Performance Lab API — environment variables
# Copy this file to .env and fill in your values for LOCAL dev.
# Never commit .env to version control.
#
# In PRODUCTION these are set in the env file on the host, not here.
# See docs/DEPLOY.md for the full deploy runbook.

# ── Database ───────────────────────────────────────────────────────────────────
# Async PostgreSQL URL. Plain postgresql:// or postgres:// are accepted and
# auto-rewritten to the asyncpg driver (see app/core/config.py).
# Local (docker-compose): the value below.
DATABASE_URL=postgresql+asyncpg://perfuser:perfpass123@localhost:5432/perflab

# ── Environment ────────────────────────────────────────────────────────────────
# Set ENVIRONMENT=production on the live host so safety checks (e.g. the
# Alembic-head check in app/main.py) fail fast instead of only logging.
ENVIRONMENT=development
DEBUG=True

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate a strong key for production: openssl rand -hex 32
SECRET_KEY=change-me-in-production-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
# Access token lifetime in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. In production you MUST pin the explicit
# prod frontend origin here — boot fails otherwise (fail-closed, INT-09):
#   ALLOWED_ORIGINS=https://perflab.44-198-76-44.nip.io
# ALLOWED_ORIGIN_REGEX is empty (disabled) by default and is REFUSED in production
# (INT-A1) — setting it fails the boot. Pin an explicit origin above instead. It is
# usable in local dev only, where it warns.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Application ───────────────────────────────────────────────────────────────
PROJECT_NAME=Performance Lab API
API_V1_STR=/v1

# ── Wearable sync (Oura — Phase 2, optional) ──────────────────────────────────
# OAuth client credentials from https://cloud.ouraring.com/oauth/applications.
# Leave blank to disable OAuth (the PAT path still works for single-user testing).
# The redirect URI must match EXACTLY what you register in the Oura console.
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=http://localhost:8000/v1/integrations/oura/callback
# Where the OAuth callback sends the browser back to after connecting.
WEB_APP_URL=http://localhost:5173
# Fernet key (urlsafe-base64, 32 bytes) encrypting wearable tokens at rest.
# Required only when using wearable sync. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=
