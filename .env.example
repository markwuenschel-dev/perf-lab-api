# Performance Lab API — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ───────────────────────────────────────────────────────────────────
# Async PostgreSQL URL (asyncpg driver).
# Plain postgresql:// or postgres:// are also accepted and auto-rewritten.
DATABASE_URL=postgresql+asyncpg://perfuser:perfpass123@localhost:5432/perflab

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=change-me-in-production-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
# Access token lifetime in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# For production add your deployment URL:
# ALLOWED_ORIGINS=http://localhost:5173,https://performancelab.netlify.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Application ───────────────────────────────────────────────────────────────
PROJECT_NAME=Performance Lab API
API_V1_STR=/v1
DEBUG=True
